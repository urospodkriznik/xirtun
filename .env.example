# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Telegram ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- LLM (Gemini to start) ---
GEMINI_API_KEY=
LLM_CHEAP_MODEL=gemini-2.5-flash-lite
LLM_STRONG_MODEL=gemini-2.5-pro

# --- Paths, timezone & schedule ---
DATA_DIR=./data
# IANA timezone name used to interpret meal/symptom times (e.g. Europe/Ljubljana).
TIMEZONE=UTC
# Cron schedule for the weekly run check — fires daily at 17:00 and runs if 7 days have passed since the last review.
WEEKLY_CRON=0 17 * * *
# Cron schedule for the morning weight-log reminder. Fires daily but only nudges on the
# morning the weekly review is due, and only if no weight was logged in the last 6 days.
# Keep it earlier in the day than WEEKLY_CRON so the nudge lands before the review runs.
WEIGHT_REMINDER_CRON=0 8 * * *
