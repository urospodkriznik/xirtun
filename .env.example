# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Telegram ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- LLM (Gemini to start) ---
GEMINI_API_KEY=
LLM_CHEAP_MODEL=gemini-2.5-flash-lite
LLM_STRONG_MODEL=gemini-2.5-pro

# --- Paths, timezone & schedule ---
DATA_DIR=./data
# IANA timezone name used to interpret meal/symptom times (e.g. Europe/Ljubljana).
TIMEZONE=UTC
# Cron for the weekly run. Default: Sunday 09:00.
WEEKLY_CRON=0 9 * * 0
